{
  "name": "expo-example",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "postinstall": "npx expo prebuild",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clean": "rm -rf node_modules android ios",
    "test": "jest",
    "test:ios": "detox test -c ios.sim.release e2e/ios e2e/shared",
    "test:android": "detox test -c android.emu.release e2e/shared e2e/android"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.11",
    "@react-native-async-storage/async-storage": "2.2.0",
